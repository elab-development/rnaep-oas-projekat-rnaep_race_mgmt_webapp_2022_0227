# Choose provider: "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (used if LLM_PROVIDER=ollama) - requires Ollama running locally
# (https://ollama.com, then `ollama pull llama3.2`)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# RaceService's PostgreSQL database. Defaults match the main ObstaRace
# docker-compose.yaml when race-db's port (5434) is published to the host.
RACE_DATABASE_URL=postgresql://obstarace:obstarace@localhost:5434/race_db
